{
  "manifestVersion": 5,
  "id": "com.supertranslatorpro.uxp",
  "name": {
    "default": "SuperTranslatorPro",
    "de": "SuperTranslatorPro"
  },
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "ID",
    "minVersion": "18.5.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "mainPanel",
      "label": {
        "default": "SuperTranslatorPro",
        "de": "SuperTranslatorPro"
      },
      "minimumSize": {
        "width": 280,
        "height": 320
      },
      "maximumSize": {
        "width": 1200,
        "height": 1400
      },
      "preferredDockedSize": {
        "width": 380,
        "height": 720
      },
      "preferredFloatingSize": {
        "width": 560,
        "height": 760
      }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": "all"
    },
    "localFileSystem": "request"
  }
}
